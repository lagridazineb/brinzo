# ---------------------------------------------------------------
# BRINZO backend configuration
# Copy this file to ".env" in this same folder and fill in values.
# ---------------------------------------------------------------

PORT=4000

# --- WhatsApp Cloud API (Meta) ---
# How to get these three values — full walkthrough is in
# server/WHATSAPP_SETUP.md, but the short version:
#
# 1. Go to https://developers.facebook.com -> "My Apps" -> "Create App"
#    -> choose "Business" type -> name it (e.g. "Brinzo Orders").
# 2. In the app dashboard, click "Add Product" -> find "WhatsApp" -> "Set up".
# 3. On the WhatsApp > API Setup page you'll immediately see:
#      - a test Phone Number ID  -> paste into WHATSAPP_PHONE_NUMBER_ID
#      - a temporary Access Token (valid 24h, fine for testing)
#                                 -> paste into WHATSAPP_ACCESS_TOKEN
#    For anything beyond quick testing, generate a PERMANENT token
#    instead — see server/WHATSAPP_SETUP.md, section "Permanent token".
# 4. WHATSAPP_RECIPIENT_NUMBER is already pre-filled below with your
#    business number (+91 80891 18428). You still need to add this
#    same number as a verified test recipient on that WhatsApp API
#    Setup page (under "To") and confirm it with the code WhatsApp
#    sends you — Meta only delivers to numbers verified that way
#    until you go through full business verification.

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_RECIPIENT_NUMBER=918746888188

# Graph API version — only change if Meta deprecates this version.
WHATSAPP_GRAPH_VERSION=v21.0

# --- WhatsApp via CallMeBot (quick, no business account needed) ---
# See server/CALLMEBOT_SETUP.md — takes ~2 minutes. Runs independently
# of the Meta Cloud API above; fine to have both, or just this one.
CALLMEBOT_PHONE=+918746888188
CALLMEBOT_APIKEY=

# --- Admin login (for the /admin dashboard) ---
# One admin account. Pick your own real values — the ones below are
# just placeholders, don't ship with them.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234
# Random long string used to sign admin session tokens. Any value
# works, just make it long and unique to you.
ADMIN_SESSION_SECRET=change-this-to-a-random-string

# --- Email notifications (optional second channel, alongside/instead of WhatsApp) ---
# Sent via the Resend API — see server/.env.example for full setup steps.
RESEND_API_KEY=re_2vXg5Kah_Dh5C5keh8wM8FZAAVtW9Bxx9
EMAIL_FROM=onboarding@resend.dev
# The address that receives every order notification email.
ADMIN_EMAIL=brinzokannur@gmail.com

# --- Google Places API (New) — powers live place search (schools, ---
# --- pharmacies, small local businesses that OpenStreetMap misses) ---
# Setup: console.cloud.google.com -> new project -> enable billing ->
# enable "Places API (New)" -> Credentials -> Create API key.
# This key is only ever used server-side (see server/places.js) —
# it is never sent to the browser.
# Leave blank to keep using the free Photon/Nominatim/local-dataset
# search — the app falls back automatically.
GOOGLE_PLACES_API_KEY=
