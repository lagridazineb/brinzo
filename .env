# Backend URL for image upload + bookings (see /server).
# Defaults to http://localhost:4000 if not set — only needed if you
# run the backend on a different port or host.
VITE_API_URL=https://brinzo.onrender.com

# Geoapify API key — enables live place search (with pharmacies,
# schools, etc.) and real road-distance/duration calculation.
# Without this, the app falls back to a small built-in Kannur dataset
# and an approximate straight-line distance.
#
# Setup (myprojects.geoapify.com):
#   1. Create a project and copy its API key (the "API keys" page,
#      same one shown in the screenshot).
#   2. Paste it below. Geoapify's free tier includes Geocoding,
#      Places, and Routing — all three are used here.
#   3. The app already restricts search results to the Kannur/Eachur
#      box in src/utils/placesService.js (KANNUR_BOUNDS) via a hard
#      "rect" filter — it does NOT search the whole world.
VITE_GEOAPIFY_API_KEY=94d16c015ba34e0d86ba20983cf78ea2
